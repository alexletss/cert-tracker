# Скопируй этот файл в .env и замени значения
# В PowerShell: copy .env.example .env

# Пароль для Postgres (минимум 16 символов)
POSTGRES_PASSWORD=ChangeMe_StrongPassword_2026

# JWT-секрет для PostgREST и Realtime (ровно 40+ символов, латиница и цифры)
JWT_SECRET=super_secret_jwt_key_change_me_to_random_40_chars_xxxxxxx

# Секретный ключ для Realtime (любая случайная строка 64+ символов)
REALTIME_SECRET_KEY_BASE=UpTo64CharactersOfRandomnessReplaceThisWithSomethingProperPlease12345

# JWT-токены — сгенерируй на https://supabase.com/docs/guides/self-hosting#api-keys
# или используй заглушки ниже (НЕ для продакшна — только для локальной сети)
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjIwMDAwMDAwMDB9.placeholder_anon_key_change_me_via_jwt_generator_with_your_secret
